# SDLL rr1,r2
:SDLL dnib1,nib2 is op8=0xB3 & dnib1 & nib0=0x7; nib3=0 & nib2 & byte0=0 {}

# SET p 179
# === dynamic ===
# --- registers  ---
# SET r1,r2
:SET nib2,nib0 is op8=0x25 & nib1 & nib0; nib3=0 & nib2 & byte0=0 
{
    nib2 = nib2 | (1 << nib0);
}

# SETB r1,r2
:SETB bnib2,nib0 is op8=0x24 & nib1=0 & nib0; nib3=0 & bnib2 & byte0=0 
{
    bnib2 = bnib2 | (1 << nib0);
}

# === static ===
# --- registers ---
# SET r1,#bit_index
:SET nib1,#nib0 is op8=0xA5 & nib1 & nib0
{
    nib1 = nib1 | (1 << nib0);
}

# SETB r1,#bit_index
:SETB bnib1,#nib0 is op8=0xA4 & bnib1 & nib0 
{
    bnib1 = bnib1 | (1 << nib0);
}

# --- indirect reg ---
# SET @r1,#bit_index
:SET @dnib1,#nib0 is op8=0x25 & dnib1 & nib0 
{
    local addr:4 = dnib1;
    local tmp:2 = *[ram]addr;
	*[ram]addr = tmp | (1 << nib0);
}

# SETB @r1,#bit_index
:SETB @dnib1,#nib0 is op8=0x24 & dnib1 & nib0 
{
    local addr:4 = dnib1;
	local tmp:1 = *[ram]:1 addr;
    *[ram]:1 addr = tmp | (1 << nib0);
}

# --- direct address ---
# SET Addr32,#bit_index
:SET Addr32,#nib0 is op8=0x65 & nib1=0 & nib0; Addr32 
{
	local tmp:2 = *[ram]:2 Addr32;
	*[ram]Addr32 =  tmp | (1 << nib0);
}

# SETB Addr32,#bit_index
:SETB Addr32,#nib0 is op8=0x64 & nib1=0 & nib0; Addr32 
{
