# TRDB p 195
# TRDB @rr1,@rr2,rx
:TRDB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0x8; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRDRB p 196
:TRDRB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0xC; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRIB p 198
:TRIB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0x0; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRIRB p 200
:TRIRB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0x4; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRTDB p 202
:TRTDB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0xA; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRTDRB p 203
:TRTDRB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0xE; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRTIB p 205
:TRTIB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0x2; nib7=0 & nib6 & dnib5 & nib4=0 {}
# TRTIRB p 207
:TRTIRB @dnib1,@dnib5,nib6 is op8=0xB8 & dnib1 & nib0=0x6; nib7=0 & nib6 & dnib5 & nib4=0xE {}

# TSET p 209
