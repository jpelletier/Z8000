:CP nib0,nib1 is op8=0x8B & nib1 & nib0 
{
	local op1:2 = nib0;
	local op2:2 = nib1;
    local result:2 = op1 - op2;
	set2_fl_16(op1, op2, result);
}

# CPB rx1,rx2
:CPB bnib0,bnib1 is op8=0x8A & bnib1 & bnib0 
{
	local op1:1 = bnib0;
	local op2:1 = bnib1;
    local result:1 = op1 - op2;
	set2_fl_8(op1, op2, result);
}

