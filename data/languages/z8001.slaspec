:SLLB bnib1,#imm16 is op8=0xB2 & bnib1 & nib0=0x1; imm_sign=0 & imm16 {}
:SLLL dnib1,#imm16 is op8=0xB3 & dnib1 & nib0=0x5; imm_sign=0 & imm16 {}

# SRA p 186
:SRA nib1,#imm16 is op8=0xB3 & nib1 & nib0=0x9; imm_sign=1 & imm16 {}
:SRAB bnib1,#imm16 is op8=0xB2 & bnib1 & nib0=0x9; imm_sign=1 & imm16 {}
:SRAL dnib1,#imm16 is op8=0xB3 & dnib1 & nib0=0xD; imm_sign=1 & imm16 {}

# SRL p 188
