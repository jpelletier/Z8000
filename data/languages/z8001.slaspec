:PUSH @dnib1,Addr32(nib0) is op8=0x53 & dnib1 & nib0; Addr32 {}

# PUSHL @rr1,Addr32(rs)
:PUSHL @dnib1,Addr32(nib0) is op8=0x51 & dnib1 & nib0; Addr32 {}

# RES p 160
# === dynamic ===
# --- registers  ---
# RES r1,r2
:RES nib2,nib0 is op8=0x23 & nib1 & nib0; nib3=0 & nib2 & byte0=0 
{
    nib2 = nib2 & ~(1 << nib0);
}

# RESB r1,r2
:RESB bnib2,nib0 is op8=0x22 & nib1=0 & nib0; nib3=0 & bnib2 & byte0=0 
{
    bnib2 = bnib2 & ~(1 << nib0);
}

# === static ===
# --- registers ---
# RES r1,#bit_index
:RES nib1,#nib0 is op8=0xA3 & nib1 & nib0
{
    nib1 = nib1 & ~(1 << nib0);
}

# RESB r1,#bit_index
:RESB bnib1,#nib0 is op8=0xA2 & bnib1 & nib0 
{
    bnib1 = bnib1 & ~(1 << nib0);
}

# --- indirect ---
# RES @r1,#bit_index
:RES @dnib1,#nib0 is op8=0x23 & dnib1 & nib0 
{
    local addr:4 = dnib1;
    local tmp:2 = *[ram]addr;
	*[ram]addr = tmp & ~(1 << nib0);
}

# RESB @r1,#bit_index
:RESB @dnib1,#nib0 is op8=0x22 & dnib1 & nib0 
{
    local addr:4 = dnib1;
	local tmp:1 = *[ram]:1 addr;
    *[ram]:1 addr = tmp & ~(1 << nib0);
}

# --- direct address ---
# RES Addr32,#bit_index
:RES Addr32,#nib0 is op8=0x63 & nib1=0 & nib0; Addr32 
{
	local tmp:2 = *[ram]:2 Addr32;
	*[ram]Addr32 =  tmp & ~(1 << nib0);
}

# RESB Addr32,#bit_index
:RESB Addr32,#nib0 is op8=0x62 & nib1=0 & nib0; Addr32 
{
	local tmp:1 = *[ram]:2 Addr32;
	*[ram]Addr32 =  tmp & ~(1 << nib0);
}

# --- indexed address ---
# RES Addr32(rs),#bit_index
:RES Addr32(nib1),#nib0 is op8=0x63 & nib1 & nib0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    local tmp:2 = *[ram]addr;
	*[ram]addr = tmp & ~(1 << nib0);
}

# RESB Addr32(rs),#bit_index
:RESB Addr32(nib1),#nib0 is op8=0x62 & nib1 & nib0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    local tmp:1 = *[ram]addr;
	*[ram]addr = tmp & ~(1 << nib0);
}

# RESFLAG p 162
# RESFLG (Reset/Clear Flag) - Uses Bitwise AND NOT (~ and &)
:RESFLG flg_list is op8=0x8D & flg_list & flg_c & flg_z & flg_s & flg_v & nib0=0x3 
{
    cf = cf & ~flg_c;
    zf = zf & ~flg_z;
    sf = sf & ~flg_s;
    vf = vf & ~flg_v;
}

