# CPSIRB @r1,@r2,r,cc
:CPSIRB @dnib5,@dnib1,nib6,cc_jp is op8=0xBA & dnib1 & nib0=0x6; nib7=0 & nib6 & dnib5 & eval_jp & cc_jp {}

# p 85
# DAB r1
:DAB bnib1 is op8=0xB0 & bnib1 & nib0=0 
{
    local val = bnib1;
    local low_nib:1 = val & 0x0F;
    local high_nib:1 = val >> 4;

	# Compute addition-specific correction rules as pure 0/1 boolean variables
    local add_low:1  = (low_nib > 9) || hf;
    local add_high:1 = (high_nib > 9) || cf || ((high_nib == 9) && (low_nib > 9));

    # Combine addition rules (df==0) and subtraction rules (df==1) using bitwise logic
    local adj_low:1  = ((df == 0) && add_low)  || ((df != 0) && hf);
    local adj_high:1 = ((df == 0) && add_high) || ((df != 0) && cf);

    # Calculate total offset adjustment value and perform dynamic execution
    local correction:1 = (adj_low * 0x06) + (adj_high * 0x60);
    
    # Select final result base based on df flag state
    local res:1 = 0;
    if (df == 0) goto <do_add>;
    res = val - correction;
    goto <do_write>;
    <do_add>
    res = val + correction;
    
    <do_write>
    # Write byte back safely into the 16-bit register context
    bnib1 = res;
    # Fast flag updates
    cf = adj_high | cf;
    zf = (res == 0:1);
    sf = (res >> 7);
}

# DEC p87
# DEC r1,n
:DEC nib1,value0 is op8=0xAB & nib1 & value0 
{
	local op2 = 1 + value0;
    nib1 = nib1 - op2;
	set_zsp_w(nib1);
}

# DECB r1,n
:DECB bnib1,value0 is op8=0xAA & bnib1 & value0 
{
	local op2:1 = 1 + value0;
    bnib1 = bnib1 - op2;
	set_zsp_b(bnib1);
}

# --- indirect reg ---
# DEC @r1
:DEC @dnib1,value0 is op8=0x2B & dnib1 & value0 
{
    local addr:4 = dnib1;
    local op1:2 = *[ram]:2 addr;
	local op2:2 = 1 + value0;
	local res:2 = op1-op2;
    *[ram]addr = res;
	set_zsp_w(res);
}

# DECB @r1
:DECB @dnib1,value0 is op8=0x2A & dnib1 & value0 
{
    local addr:4 = dnib1;
    local op1:1 = *[ram]addr;
	local op2:1 = 1 + value0;
	local res:1 = op1-op2;
    *[ram]addr = res;
	set_zsp_b(res);
}

# --- direct address ---
# DEC Addr32
:DEC Addr32,value0 is op8=0x6B & nib1=0 & value0; Addr32 
{
    local op1:2 = *[ram]Addr32;
	local op2:2 = 1 + value0;
	local res:2 = op1-op2;
	*[ram]Addr32 = res;
	set_zsp_w(res);
}

# DECB Addr32
:DECB Addr32,value0 is op8=0x6A & nib1=0 & value0; Addr32 
{
    local op1:1 = *[ram]Addr32;
	local op2:1 = 1 + value0;
	local res:1 = op1-op2;
	*[ram]Addr32 = res;
	set_zsp_b(res);
}

# --- indexed address ---
# DEC Addr32(rs)
:DEC Addr32(nib1),value0 is op8=0x6B & nib1 & value0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    local op1:2 = *[ram]addr;
	local op2:2 = 1 + value0;
	local res:2 = op1-op2;
	*[ram]Addr32 = res;
	set_zsp_w(res);
}

# DECB Addr32(rs)
:DECB Addr32(nib1),value0 is op8=0x6A & nib1 & value0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    local op1:1 = *[ram]addr;
	local op2:1 = 1 + value0;
	local res:1 = op1-op2;
	*[ram]Addr32 = res;
	set_zsp_w(res);
}

