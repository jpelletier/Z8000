# ---------------------------------------------------------
# Load Register
# ---------------------------------------------------------
# --- registers  ---
# LD r1,r2
:LD nib0,nib1 is op8=0xA1 & nib1 & nib0 
{
    nib0 = nib1;
}

# LDB r1,r2
:LDB bnib0,bnib1 is op8=0xA0 & bnib1 & bnib0 
{
    bnib0 = bnib1;
}

# LDL rr1,rr2
:LDL dnib0,dnib1 is op8=0x94 & dnib1 & dnib0 
{
    dnib0 = dnib1;
}

# --- indirect ---
# LD r1,@rr2
:LD nib0,@dnib1 is op8=0x21 & dnib1 & nib0 
{
    # Construct target address out of the source 32-bit pointer register
    local target:4;
    getLinearAddress(dnib1,target);
    
    # Read a 16-bit word from the computed RAM address
    nib0 = *:2 target;
}

# LDB r1,@rr2
:LDB bnib0,@dnib1 is op8=0x20 & dnib1 & bnib0 
{
    # Construct target address out of the source 32-bit pointer register
    local target:4;
    getLinearAddress(dnib1,target);
    
    # Read a 16-bit word from the computed RAM address
    bnib0 = *:1 target;
}

# LDL rr1,@rr2
:LDL dnib0,@dnib1 is op8=0x14 & dnib1 & dnib0 
{
    # Construct target address out of the source 32-bit pointer register
    local target:4;
    getLinearAddress(dnib1,target);
    
    # Read a 16-bit word from the computed RAM address
    dnib0 = *:2 target;
}

