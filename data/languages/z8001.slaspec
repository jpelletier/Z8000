:RR nib1,"#1" is op8=0xB3 & nib1 & nib0=0x4 {}
:RR nib1,"#2" is op8=0xB3 & nib1 & nib0=0x6 {}

# RRB r1,#n
:RRB bnib1,"#1" is op8=0xB2 & bnib1 & nib0=0x4 {} 
:RRB bnib1,"#1" is op8=0xB2 & bnib1 & nib0=0x6 {} 

# RRC p 169
# RRC r1,#n
:RRC nib1,"#1" is op8=0xB3 & nib1 & nib0=0xC {}
:RRC nib1,"#2" is op8=0xB3 & nib1 & nib0=0xE {}

# RRCB r1,#n
:RRCB nib1,"#1" is op8=0xB2 & nib1 & nib0=0xC {}
:RRCB nib1,"#2" is op8=0xB2 & nib1 & nib0=0xE {}

# RRDB p 170
