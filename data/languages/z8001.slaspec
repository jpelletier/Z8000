:RLC nib1,"#2" is op8=0xB3 & nib1 & nib0=0xA {}

# RLCB r1,#n
:RLCB nib1,"#1" is op8=0xB2 & nib1 & nib0=0x8 {}
:RLCB nib1,"#2" is op8=0xB2 & nib1 & nib0=0xA {}

# RLDB p 166
# RLDB r1,r2
:RLDB nib0,nib1 is op8=0xBE & nib1 & nib0 {}

# RR p 168
