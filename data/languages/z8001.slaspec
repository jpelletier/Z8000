# --- Interrupt Return (IRET) ---
# Native Z8000 Opcode: 0x7B00
# Z8001 Segmented Behavior: Pops FCW (2 bytes) then pops the segmented PC (4 bytes) 
# off the system stack tracker (r15).
:IRET is op16=0x7B00 
{
    local stack_ptr:4;
    
    # 1. Pop the 16-bit FCW status word from the stack
    getLinearAddress(rr14,stack_ptr);
    FCW = *:2 stack_ptr;
    rr14 = rr14 + 2; # Adjust stack pointer up
    
    # 2. Pop the 32-bit Segmented Program Counter from the stack
    getLinearAddress(rr14,stack_ptr);
    local target_pc:4 = *:4 stack_ptr;
    rr14 = rr14 + 4; # Adjust stack pointer up
    
    # 3. Reconstruct and jump directly to the target linear address space
    local linear_pc:4;
    getLinearAddress(target_pc,linear_pc);
    return [linear_pc];
}

