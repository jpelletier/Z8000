# DJNZ p 92
:DJNZ nib2,rel7 is op4=0xF & nib2 & W=1 & rel7 
{
	nib2 = nib2-1;
	if (nib2 != 0) goto rel7;
}

:DBJNZ bnib2,rel7 is op4=0xF & bnib2 & W=0 & rel7 
{
	bnib2 = bnib2-1;
	if (bnib2 != 0) goto rel7;
}

