:SRLB bnib1,#imm16 is op8=0xB2 & bnib1 & nib0=0x1; imm_sign=1 & imm16 {}
:SRLL dnib1,#imm16 is op8=0xB3 & dnib1 & nib0=0x5; imm_sign=1 & imm16 {}

# p 190 SUB
# --- registers  ---
# SUB r1,r2
:SUB nib0,nib1 is op8=0x83 & nib1 & nib0 
{
	local op1:2 = nib0;
	local op2:2 = nib1;
    local result:2 = op1 - op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# SUBB rx1,rx2
:SUBB bnib0,bnib1 is op8=0x82 & bnib1 & bnib0 
{
	local op1:1 = bnib0;
	local op2:1 = bnib1;
    local result:1 = op1 - op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# SUBL rr1,rr2
:SUBL dnib0,dnib1 is op8=0x92 & dnib0 & dnib1 
{
	local op1:4 = dnib0;
	local op2:4 = dnib1;
    local result:4 = op1 - op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- immediate ---
# SUB r1,#val16
:SUB nib0,#imm16 is op8=0x02 & nib1=0 & nib0; imm16 
{
	local op1:2 = nib0;
    local op2:2 = imm16;
    local result:2 = op1 - op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# SUBB rx1,#val16
:SUBB bnib0,#imm16 is op8=0x03 & nib1=0 & bnib0; imm16 
{
	local op1:1 = bnib0;
    local op2:1 = imm16 & 0xff;
    local result:1 = op1 - op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# SUBL r1,#val32
:SUBL dnib0,#imm32 is op8=0x12 & dnib1=0 & dnib0; imm32 
{
	local op1:4 = dnib0;
    local op2:4 = imm32;
    local result:4 = op1 - op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- indirect reg ---
# SUB r1,@r2
:SUB nib0,@dnib1 is op8=0x03 & dnib1 & nib0 
{
	local op1:2 = nib0;
    local addr:4 = dnib1;
    local op2:2 = *[ram]:2 addr;
    local result:2 = op1 - op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# SUBB rx1,@r2
:SUBB bnib0,@dnib1 is op8=0x02 & dnib1 & bnib0 
{
	local op1:1 = bnib0;
    local addr:4 = dnib1;
    local op2:1 = *[ram]:2 addr;
    local result:1 = op1 - op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# SUBL r1,@r2
:SUBL dnib0,@dnib1 is op8=0x12 & dnib1 & dnib0 
{
	local op1:4 = dnib0;
    local addr:4 = dnib1;
    local op2:4 = *[ram]:2 addr;
    local result:4 = op1 - op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- direct address ---
# SUB r1,Addr32
:SUB nib0,Addr32 is op8=0x43 & nib1=0 & nib0; Addr32 
{
	local op1:2 = nib0;
    local op2:2 = *[ram]Addr32;
    local result:2 = op1 - op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# SUBB r1,Addr32
:SUBB bnib0,Addr32 is op8=0x42 & nib1=0 & bnib0; Addr32 
{
	local op1:1 = bnib0;
    local op2:1 = *[ram]Addr32;
    local result:1 = op1 - op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# SUBL r1,Addr32
:SUBL dnib0,Addr32 is op8=0x52 & nib1=0 & dnib0; Addr32 
{
	local op1:4 = dnib0;
    local op2:4 = *[ram]Addr32;
    local result:4 = op1 - op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- indexed address ---
# SUB r1,Addr32(rs)
:SUB nib0,Addr32(nib1) is op8=0x43 & nib1 & nib0; Addr32 
{
	local op1:2 = nib0;
    local addr:4 = zext(nib1);
    local op2 = *[ram](addr + zext(nib1));
    local result:2 = op1 - op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# SUBB rx1,Addr32(rs)
:SUBB bnib0,Addr32(nib1) is op8=0x42 & nib1 & bnib0; Addr32 
{
	local op1:1 = bnib0;
    local addr:4 = zext(nib1);
    local op2:1 = *[ram]:1 (addr + zext(nib1));
    local result:1 = op1 - op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# SUBL rr1,Addr32(rs)
:SUBL dnib0,Addr32(nib1) is op8=0x52 & nib1 & dnib0; Addr32 
{
	local op1:4 = dnib0;
    local addr:4 = zext(nib1);
    local op2:4 = *[ram]:4 (addr + zext(nib1));
    local result:4 = op1 - op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

