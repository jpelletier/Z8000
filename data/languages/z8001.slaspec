# p 72
# CPD: Compare and Decrement
:CPD nib5,@dnib1,nib6,cc_jp is op8=0xBB & dnib1 & nib0=0x8; nib7=0 & nib6 & nib5 & eval_jp & cc_jp 
{
#    local mem_byte:1 = *[ram]dnib1;
#    local src_byte:1 = nib5:1;
    
#    zf = (src_byte == mem_byte);
#    sf = (src_byte < mem_byte);
    
#    nib6 = nib6 - 1:2;
#    vf = (nib6 != 0:2);
#    dnib1 = dnib1 - 2:4;
}

# CPDB: Compare and Decrement
:CPDB bnib5,@dnib1,nib6,cc_jp is op8=0xBA & dnib1 & nib0=0x8; nib7=0 & nib6 & bnib5 & eval_jp & cc_jp 
{
#    local mem_byte = *[ram]dnib1;
#    local src_byte = bnib5;
#    
#    zf = (src_byte == mem_byte);
#    sf = (src_byte < mem_byte);
    
#    nib6 = nib6 - 1:2;
#    vf = (nib6 != 0:2);
#    dnib1 = dnib1 - 1:4;
}

# p 73
# CPDR: Compare,Decrement,and Repeat
:CPDR nib5,@dnib1,nib6,cc_jp is op8=0xBB & dnib1 & nib0=0xC; nib7=0 & nib6 & nib5 & eval_jp & cc_jp  
{
    <loop_start>
    local mem_byte:1 = *[ram]dnib1;
    local src_byte:1 = nib5:1;
    
    zf = (src_byte == mem_byte);
    sf = (src_byte < mem_byte);
    
    nib6 = nib6 - 1:2;
    vf = (nib6 != 0:2);
    dnib1 = dnib1 - 2:4;
    
    if (vf && !zf) goto <loop_start>;
}

# CPDRB: Compare,Decrement,and Repeat
:CPDRB bnib5,@dnib1,nib6,cc_jp is op8=0xBA & dnib1 & nib0=0xC; nib7=0 & nib6 & bnib5 & eval_jp & cc_jp  
{
    <loop_start>
    local mem_byte:1 = *[ram]dnib1;
    local src_byte = bnib5;
    
    zf = (src_byte == mem_byte);
    sf = (src_byte < mem_byte);
    
    nib6 = nib6 - 1:2;
    vf = (nib6 != 0:2);
    dnib1 = dnib1 - 1:4;
    
    if (vf && !zf) goto <loop_start>;
}

# p 74
# CPI: Compare and Increment
:CPI nib5,@dnib1,nib6,cc_jp is op8=0xBB & dnib1 & nib0=0; nib7=0 & nib6 & nib5 & eval_jp & cc_jp 
{
    local mem_byte:1 = *[ram]dnib1;
    local src_byte:1 = nib5:1;
    
    zf = (src_byte == mem_byte);
    sf = (src_byte < mem_byte);
    
    nib6 = nib6 - 1:2;
    vf = (nib6 != 0:2);
    dnib1 = dnib1 + 2:4;
}

# CPIB: Compare and Increment
:CPIB nib5,@dnib1,nib6,cc_jp is op8=0xBA & dnib1 & nib0=0; nib7=0 & nib6 & nib5 & eval_jp & cc_jp 
{
    local mem_byte:1 = *[ram]dnib1;
    local src_byte:1 = nib5:1;
    
    zf = (src_byte == mem_byte);
    sf = (src_byte < mem_byte);
    
    nib6 = nib6 - 1:2;
    vf = (nib6 != 0:2);
    dnib1 = dnib1 + 1:4;
}

