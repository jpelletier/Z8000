	*[ram]Addr32 =  tmp | (1 << nib0);
}

# --- indexed address ---
# SET Addr32(rs),#bit_index
:SET Addr32(nib1),#nib0 is op8=0x65 & nib1 & nib0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    local tmp:2 = *[ram]addr;
	*[ram]addr = tmp | (1 << nib0);
}

# SETB Addr32(rs),#bit_index
:SETB Addr32(nib1),#nib0 is op8=0x64 & nib1 & nib0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    local tmp:1 = *[ram]addr;
	*[ram]addr = tmp | (1 << nib0);
}

# SETFLG p 181
# SETFLG (Set Flag) - Uses Bitwise OR (|)
:SETFLG flg_list is op8=0x8D & flg_list & flg_c & flg_z & flg_s & flg_v & nib0=0x1
{
    cf = cf | flg_c;
    zf = zf | flg_z;
    sf = sf | flg_s;
    vf = vf | flg_v;
}

# SLA p 182
# SLA r1,#n
:SLA nib1,#imm16 is op8=0xB3 & nib1 & nib0=0x9; imm_sign=0 & imm16 {}
:SLAB bnib1,#imm16 is op8=0xB2 & bnib1 & nib0=0x9; imm_sign=0 & imm16 {}
:SLAL dnib1,#imm16 is op8=0xB3 & dnib1 & nib0=0xD; imm_sign=0 & imm16 {}

# SLL p 184
