    zf = (src_byte == mem_byte);
    sf = (src_byte < mem_byte);
    
    nib6 = nib6 - 1:2;
    vf = (nib6 != 0:2);
    dnib1 = dnib1 + 2:4;
    
    if (vf && !zf) goto <loop_start>;
}

# CPIRB: Compare,Increment,and Repeat
:CPIRB nib5,@dnib1,nib6,cc_jp is op8=0xBA & dnib1 & nib0=0x4; nib7=0 & nib6 & nib5 & eval_jp & cc_jp 
{
    <loop_start>
    local mem_byte:1 = *[ram]dnib1;
