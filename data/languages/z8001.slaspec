{
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
}

# --- indirect reg ---
# TSET @r1
:TSET @dnib1 is op8=0x0D & dnib1 & nib0=0x6
{
    local addr:4 = dnib1;
    local mem_val:2 = *[ram]:2 addr;
	local res:2 = mem_val;
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
}

# TSETB @r1
:TSETB @dnib1 is op8=0x0C & dnib1 & nib0=0x6
{
    local addr:4 = dnib1;
    local mem_val:1 = *[ram]:1 addr;
	local res:1 = mem_val;
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
}

# --- direct address ---
# TSET Addr32
:TSET Addr32 is op8=0x4D & nib1=0 & nib0=0x6; Addr32
{
    local mem_val:2 = *[ram]Addr32;
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
}

# TSETB Addr32
:TSETB Addr32 is op8=0x4C & nib1=0 & nib0=0x6; Addr32
{
    local mem_val:1 = *[ram]Addr32;
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
}

# --- indexed address ---
# TSET Addr32(rs)
:TSET Addr32(nib1) is op8=0x4D & nib1 & nib0=0x6; Addr32
{
    local addr:4 = zext(nib1);
    local mem_val:2 = *[ram]:2 (addr + zext(nib1));
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
}

# TSETB Addr32(rs)
:TSETB Addr32(nib1) is op8=0x4C & nib1 & nib0=0x6; Addr32
{
    local addr:4 = zext(nib1);
    local mem_val:1 = *[ram]:1 (addr + zext(nib1));
	goto inst_next;	#FIXME FUNCTION NOT IMPLEMENTED
