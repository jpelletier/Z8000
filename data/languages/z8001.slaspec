}

# LDL r1(#imm16),rr2
:LDL nib1(#imm16),dnib0 is op8=0x37 & nib1 & dnib0; imm16 
{
	local tmpOffset:4 = zext(nib1 + imm16);
    *[ram]:4 tmpOffset = dnib0;
}

# --- base index ---
# LD r1(rx),r2
:LD dnib1(nib6),nib0 is op8=0x73 & dnib1 & nib0; nib7=0 & nib6 & byte0=0 
{
    local addr:4 = dnib1 + zext(nib6);
    *[ram]addr = nib0;
}

# LDB r1(rx),rx2
:LDB dnib1(nib6),bnib0 is op8=0x72 & dnib1 & bnib0; nib7=0 & nib6 & byte0=0 
{
    local addr:4 = dnib1 + zext(nib6);
    *[ram]addr = bnib0;
}

# LDL r1(rx),rr2
:LDL dnib1(nib6),dnib0 is op8=0x77 & dnib1 & dnib0; nib7=0 & nib6 & byte0=0 
{
    local addr:4 = dnib1 + zext(nib6);
    *[ram]addr = dnib0;
}

# ---------------------------------------------------------
# Load Immediate
# ---------------------------------------------------------
# --- registers  ---
# LD r1,#0x1234
:LD nib0,#imm16 is op8=0x21 & nib1=0 & nib0; imm16 
{
    nib0 = imm16;
}

# LDB rx1,#0x12
:LDB bnib2,#byte0 is op4=0xC & bnib2 & byte0 
{
    bnib2 = byte0;
}

# LDL rr1,#0x1234
:LDL dnib0,#imm32 is op8=0x14 & nib1=0 & dnib0; imm32 
{
    dnib0 = imm32;
}

# --- indirect ---
# LD @rr1,#0x1234
:LD @dnib1,#imm16 is op8=0x0D & dnib1 & nib0=0x5; imm16 
{
    local addr:4 = dnib1;
    *[ram]:2 addr = imm16;
}

# LDB @rr1,#0x1234
:LDB @dnib1,#imm16 is op8=0x0C & dnib1 & nib0=0x5; imm16 
{
    local addr:4 = dnib1;
    *[ram]:1 addr = imm16;
}

# --- direct address ---
# LD Addr32,#0x1234
:LD Addr32,#imm16 is op16=0x4D05; Addr32; imm16 
{
    *[ram]:2 Addr32 = imm16;
}

# LDB Addr32,#0x1234
:LDB Addr32,#imm16 is op16=0x4C05; Addr32; imm16 
{
    *[ram]:1 Addr32 = imm16;
}

# --- indexed address ---
# LD Addr32(r1),#0x1234
:LD Addr32(nib1),#imm16 is op8=0x4D & nib1 & nib0=0x5; Addr32; imm16 
{
    local addr:4 = Addr32 + zext(nib1);
    *[ram]:2 addr = imm16;
}

# LDB Addr32(r1),#0x1234
:LDB Addr32(nib1),#imm16 is op8=0x4C & nib1 & nib0=0x5; Addr32; imm16 
{
    local addr:4 = Addr32 + zext(nib1);
    *[ram]:1 addr = imm16;
}

# LDA
#   CODE ASSEMBLED WITH GNU AS DOESN'T HAVE THE SEGMENT BIT SET
# LDA p 113
# LDA rr1, Address
# --- direct address ---
# LDA rr1, Addr32
:LDA dnib0, Addr32 is op8=0x76 & nib1=0 & dnib0; Addr32 
{
    dnib0 = Addr32;
}

# --- indexed address ---
# LDA rr1, Addr32(rs)
:LDA dnib0, Addr32(nib1) is op8=0x76 & nib1 & dnib0; Addr32 
{
    local addr:4 = Addr32 + zext(nib1);
    dnib0 = addr;
}

# --- base address ---
# LDA rr1, r2(#imm16)
:LDA dnib0, nib1(#imm16) is op8=0x34 & nib1 & dnib0; imm16 
{
	local tmp:4 = zext(nib1 + imm16);
    dnib0 = *[ram]tmp;
}

# --- base index ---
# LDA rr1, r2(rx)
:LDA dnib0, nib1(nib6) is op8=0x74 & nib1 & dnib0; nib7=0 & nib6 & byte0=0 
{
	local tmp:4 = zext(nib1 + nib6);
	dnib0 = *[ram]tmp;
}

# LDAR p 115
# LDAR rr1,address
:LDAR dnib0,imm16 is op8=0x34 & nib1=0 & dnib0; imm16 
{
	local tmp_data = inst_next + imm16;
    dnib0 = tmp_data;
}

#attach names [ ctlr ] 
#[
#	_ _ "FCW" "REFRESH" "PSAPSEG" "PSAPOFF" "NSPSEG" "NSPOFF"
#];

# LDCTL p 116
:LDCTL "FCW",nib1 	   is op8=0x7D & nib1 & dirr=1 & ctlr=0x2 { FCW = nib1 & 0xF8FC; }
:LDCTL "REFRESH",nib1 is op8=0x7D & nib1 & dirr=1 & ctlr=0x3 { REFRESH = nib1 & 0xFFFE; }
:LDCTL "PSAPSEG",nib1 is op8=0x7D & nib1 & dirr=1 & ctlr=0x4 { PSAPSEG = nib1 & 0x7F00; }
:LDCTL "PSAPOFF",nib1 is op8=0x7D & nib1 & dirr=1 & ctlr=0x5 { PSAPOFF = nib1 & 0xFF00; }
:LDCTL "NSPSEG",nib1  is op8=0x7D & nib1 & dirr=1 & ctlr=0x6 { NSPSEG = nib1; }
:LDCTL "NSPOFF",nib1  is op8=0x7D & nib1 & dirr=1 & ctlr=0x7 { NSPOFF = nib1; }

:LDCTL nib1,"FCW"     is op8=0x7D & nib1 & dirr=0 & ctlr=0x2 { nib1 = FCW; }
:LDCTL nib1,"REFRESH" is op8=0x7D & nib1 & dirr=0 & ctlr=0x3 { nib1 = REFRESH & 0xFFFE; }
:LDCTL nib1,"PSAPSEG" is op8=0x7D & nib1 & dirr=0 & ctlr=0x4 { nib1 = PSAPSEG; }
:LDCTL nib1,"PSAPOFF" is op8=0x7D & nib1 & dirr=0 & ctlr=0x5 { nib1 = PSAPOFF; }
:LDCTL nib1,"NSPSEG"  is op8=0x7D & nib1 & dirr=0 & ctlr=0x6 { nib1 = NSPSEG; }
:LDCTL nib1,"NSPOFF"  is op8=0x7D & nib1 & dirr=0 & ctlr=0x7 { nib1 = NSPOFF; }

# LDCTLB p 121
:LDCTLB "FLAGS",bnib1 is op8=0x8C & bnib1 & nib0=0x9
{ 
    # Create a local temporary variable sized to match FCW (2 bytes)
    local tmp:2 = zext(bnib1) & 0x00FC; 
    FCW = tmp; 
}

:LDCTLB bnib1,"FLAGS" is op8=0x8C & bnib1 & nib0=0x1
{ 
    # Truncate the 16-bit register down to a 1-byte varnode and mask it
    regDestByte = FCW:1 & 0xFC; 
}

# LDD p 123
# LDD @rr1,@rr2,r
:LDD @dnib1,@dnib5,nib6  is op8=0xBB & dnib1 & nib0=0x9; nib7=0 & nib6 & dnib5 & nib4=0x8
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:2 dest = *[ram]:2 src;
	dnib1 = dnib1-2;
	dnib5 = dnib5-2;
	nib6 = nib6-1;
	vf = (nib6 == 0);
}

:LDDB @dnib1,@dnib5,nib6 is op8=0xBA & dnib1 & nib0=0x9; nib7=0 & nib6 & dnib5 & nib4=0x8
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:1 dest = *[ram]:1 src;
	dnib1 = dnib1-1;
	dnib5 = dnib5-1;
	nib6 = nib6-1;
	vf = (nib6 == 0);
}

# LDDR p 124
# LDDR @rr1,@rr2,r
:LDDR @dnib1,@dnib5,nib6  is op8=0xBB & dnib1 & nib0=0x9; nib7=0 & nib6 & dnib5 & nib4=0
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:2 dest = *[ram]:2 src;
	dnib1 = dnib1-2;
	dnib5 = dnib5-2;
	nib6 = nib6-1;
	if (nib6 != 0) goto inst_start;
	vf = 1;
}

:LDDRB @dnib1,@dnib5,nib6 is op8=0xBA & dnib1 & nib0=0x9; nib7=0 & nib6 & dnib5 & nib4=0
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:1 dest = *[ram]:1 src;
	dnib1 = dnib1-1;
	dnib5 = dnib5-1;
	nib6 = nib6-1;
	if (nib6 != 0) goto inst_start;
	vf = 1;
}

# LDI p 126
# LDI @rr1,@rr2,r
:LDI @dnib1,@dnib5,nib6  is op8=0xBB & dnib1 & nib0=0x1; nib7=0 & nib6 & dnib5 & nib4=0x8
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:2 dest = *[ram]:2 src;
	dnib1 = dnib1+2;
	dnib5 = dnib5+2;
	nib6 = nib6-1;
	vf = (nib6 == 0);
}

:LDIB @dnib1,@dnib5,nib6 is op8=0xBA & dnib1 & nib0=0x1; nib7=0 & nib6 & dnib5 & nib4=0x8
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:1 dest = *[ram]:1 src;
	dnib1 = dnib1+1;
	dnib5 = dnib5+1;
	nib6 = nib6-1;
	vf = (nib6 == 0);
}

# LDIR p 127
# LDIR @rr1,@rr2,r
:LDIR @dnib1,@dnib5,nib6  is op8=0xBB & dnib1 & nib0=0x1; nib7=0 & nib6 & dnib5 & nib4=0
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:2 dest = *[ram]:2 src;
	dnib1 = dnib1+2;
	dnib5 = dnib5+2;
	nib6 = nib6-1;
	if (nib6 != 0) goto inst_start;
	vf = 1;
}

:LDIRB @dnib1,@dnib5,nib6 is op8=0xBA & dnib1 & nib0=0x1; nib7=0 & nib6 & dnib5 & nib4=0
{
    local dest:4 = dnib1;
    local src:4 = dnib5;
	*[ram]:1 dest = *[ram]:1 src;
	dnib1 = dnib1+1;
	dnib5 = dnib5+1;
	nib6 = nib6-1;
	if (nib6 != 0) goto inst_start;
	vf = 1;
}

# LDK p 129
# LDK r1,1data
:LDK nib1,#value0 is op8=0xBD & nib1 & value0 { nib1 = value0; }

# LDM p 130
# FIXME ASSEMBLER #7 DISASSEMBLER #6
# --- indirect ---
# LDM r1,@r2,#n
:LDM nib6,dnib1,#value0 is op8=0x1C & dnib1 & nib0=0x1; nib7=0 & nib6 &nib5=0 & value0
{
#	local nb:1 = value0:1+1;
#<ldm_loop>
#	nib6 = *[ram]:2 dnib1;		
	# FIXME how to increment register number (nib6 = R0 to R15), not its content
#	dnib1 = dnib1+1;
#	nb = nb-1;
#	if (nb != 0) goto <ldm_loop>;
}

# --- direct address ---
# LDM r1,address,#n
:LDM nib6,Addr32,#value0 is op16=0x5C01; nib7=0 & nib6 & nib5=0 & value0; Addr32 { }

# --- indexed address ---
# LDM r1,Addr32(r1),#n
:LDM nib6,Addr32(nib1),#value0 is op8=0x5C & nib1 & nib0=0x1; nib7=0 & nib6 & nib5=0 & value0; Addr32 {}

# --- indirect ---
# LDM @r1,r2,#n
:LDM dnib1,nib6,#value0 is op8=0x1C & dnib1 & nib0=0x9; nib7=0 & nib6 &nib5=0 & value0 { }

# --- direct address ---
# LDM Addr32,r1,#n
:LDM Addr32,nib6,#value0 is op16=0x5C09; nib7=0 & nib6 & nib5=0 & value0; Addr32 { }

# --- indexed address ---
# LDM Addr32(r1),r2,#n
:LDM Addr32(nib1),nib6,#value0 is op8=0x5C & nib1 & nib0=0x9; nib7=0 & nib6 & nib5=0 & value0; Addr32 {}

# LDPS p 133
# --- indirect ---
# LDPS @rr1
:LDPS dnib1 is op8=0x39 & dnib1 & nib0=0
{
#    local src = dnib1;
	# FIXME verify if PC and FSW are loaded correcly
#	pc = *[ram]src;
#	FSW = *[ram](src+2);
}

# --- direct address ---
# LDPS Addr32
:LDPS Addr32 is op16=0x7900; Addr32 { }

# --- indexed address ---
# LDPS Addr32(r1)
:LDPS Addr32(nib1) is op8=0x79 & nib1 & nib0=0; Addr32 {}

# LDR p 134
:LDR nib0, rel16   is op8=0x31 & nib1=0 & nib0; rel16
{
	local addr:4 = rel16;
	nib0 = *[ram]addr;
}

:LDRB bnib0, rel16 is op8=0x30 & nib1=0 & bnib0; rel16
{
	local addr:4 = rel16;
	bnib0 = *[ram]addr;
}
:LDRL dnib0, rel16 is op8=0x35 & nib1=0 & dnib0; rel16
{
	local addr:4 = rel16;
	dnib0 = *[ram]addr;
}

:LDR rel16,nib0    is op8=0x33 & nib1=0 & nib0; rel16
{
	local addr:4 = rel16;
	*[ram]addr = nib0;
}

:LDRB rel16,bnib0  is op8=0x32 & nib1=0 & bnib0; rel16
{
	local addr:4 = rel16;
	*[ram]addr = bnib0;
}

:LDRL rel16,dnib0  is op8=0x37 & nib1=0 & dnib0; rel16
{
	local addr:4 = rel16;
	*[ram]addr = dnib0;
}

# ---------------------------------------------------------
# FIXME Not used for a single Z8001 in the system
# MBIT p 136
:MBIT is op16=0x7B0A {}
# MREQ p 137
:MREQ nib1 is op8=0x7B & nib1 & nib0=0xD {}
# MRES p 139
:MRES is op16=0x7B09 {}
# MSET p 140
:MSET is op16=0x7B08 {}
# ---------------------------------------------------------
# MULT p 141
# --- registers  ---
# MULT rr1,r2
:MULT dnib0,nib1 is op8=0x99 & nib1 & dnib0 {}

# MULTL rq1,rr2
:MULTL qnib0,dnib1 is op8=0x98 & dnib1 & qnib0 {}

# --- immediate ---
# MULT rr1,#data
:MULT dnib0,#imm16 is op8=0x19 & nib1=0 & dnib0; imm16 {}

# MULTL rq1,#data
:MULTL qnib0,#imm32 is op8=0x18 & nib1=0 & qnib0; imm32 {}

# --- indirect ---
# MULT rr1,@r2
:MULT dnib0,@dnib1 is op8=0x19 & dnib1 & dnib0 {}

# MULTL rq1,@r2
:MULTL qnib0,@dnib1 is op8=0x18 & dnib1 & qnib0 {}

# --- direct address ---
# MULT rr1,address
:MULT dnib0,Addr32 is op8=0x59 & nib1=0 & dnib0; Addr32 {}

# MULTL rq1,address
:MULTL qnib0,Addr32 is op8=0x58 & nib1=0 & qnib0; Addr32 {}

# --- indexed address ---
# MULT rr1,addr(r2)
:MULT dnib0,Addr32(nib1) is op8=0x59 & nib1 & dnib0; Addr32 {}

# MULTL rq1,addr(r2)
:MULTL qnib0,Addr32(nib1) is op8=0x58 & nib1 & qnib0; Addr32 {}

# ---------------------------------------------------------
# NEG p 144
# NEG r1
:NEG nib1 is op8=0x8D & nib1 & nib0=2 
{
    nib1 = -nib1;
	set_zs_w(nib1);
	vf = (nib1 == 0x8000);
}

# NEGB r1
:NEGB bnib1 is op8=0x8C & bnib1 & nib0=2 
{
    bnib1 = -bnib1;
	set_zs_b(bnib1);
	vf = (bnib1 == 0x80);
}

# --- indirect reg ---
# NEG @r1
:NEG @dnib1 is op8=0x0D & dnib1 & nib0=2 
{
    local addr:4 = dnib1;
    local op1:2 = *[ram]:2 addr;
	local res:2 = -op1;
    dnib1 = zext(res);
	set_zs_w(res);
	vf = (res == 0x8000);
}

# NEGB @r1
:NEGB @dnib1 is op8=0x0C & dnib1 & nib0=2 
{
    local addr:4 = dnib1;
    local op1:1 = *[ram]:1 addr;
	local res:1 = -op1;
    dnib1 = zext(res);
	set_zs_b(res);
	vf = (res == 0x80);
}

# --- direct address ---
# NEG Addr32
:NEG Addr32 is op8=0x4D & nib1=0 & nib0=2; Addr32 
{
    local op1:2 = *[ram]Addr32;
	local res:2 = -op1;
	*[ram]Addr32 = res;
	set_zs_w(res);
	vf = (res == 0x8000);
}

# NEGB Addr32
:NEGB Addr32 is op8=0x4C & nib1=0 & nib0=2; Addr32 
{
    local op1:1 = *[ram]Addr32;
	local res:1 = -op1;
	*[ram]Addr32 = res;
	set_zs_b(res);
	vf = (res == 0x80);
}

# --- indexed address ---
# NEG Addr32(rs)
:NEG Addr32(nib1) is op8=0x4D & nib1 & nib0=2; Addr32 
{
    local addr:4 = zext(nib1);
    local op1:2 = *[ram]:2 (addr + zext(nib1));
	local res:2 = -op1;
    *[ram]:2 (addr + zext(nib1)) = res;
	set_zs_w(res);
	vf = (res == 0x8000);
}

# NEGB Addr32(rs)
:NEGB Addr32(nib1) is op8=0x4C & nib1 & nib0=2; Addr32 
{
    local addr:4 = zext(nib1);
    local op1:1 = *[ram]:1 (addr + zext(nib1));
	local res:1 = -op1;
    *[ram]:1 (addr + zext(nib1)) = res;
	set_zs_b(res);
	vf = (res == 0x80);
}

# --- No Operation (NOP) ---
# Native Z8000 Opcode: 0x8D07 (ld r0,r0 acts as the official NOP)
:NOP is op16=0x8D07 
{
	goto inst_next;
}

# p 146
# --- registers  ---
# OR r1,r2
:OR nib0,nib1 is op8=0x85 & nib1 & nib0 
{
    nib0 = nib0 | nib1;
	set_zs_w(nib0);
}

# ORB r1,r2
:ORB bnib0,bnib1 is op8=0x84 & bnib1 & bnib0 
{
    bnib0 = bnib0 | bnib1;
	set_zsp_b(bnib0);
}

# --- immediate ---
# OR r1,#val16
:OR nib0,#imm16 is op8=0x05 & nib1=0 & nib0; imm16 
{
    local imm_val:2 = imm16;
    nib0 = nib0 | imm_val;
	set_zs_w(nib0);
}

# ORB r1,#val16
:ORB bnib0,#imm16 is op8=0x04 & nib1=0 & bnib0; imm16 
{
    local imm_val:1 = imm16;
    bnib0 = bnib0 | imm_val;
	set_zsp_b(bnib0);
}

# --- indirect reg ---
# OR r1,@r2
:OR nib0,@dnib1 is op8=0x05 & dnib1 & nib0 
{
    local addr:4 = dnib1;
    local mem_val:2 = *[ram]:2 addr;
    nib0 = nib0 | mem_val;
	set_zs_w(nib0);
}

# ORB r1,@r2
:ORB bnib0,@dnib1 is op8=0x04 & dnib1 & bnib0 
{
    local addr:4 = dnib1;
    local mem_val:1 = *[ram]addr;
    bnib0 = bnib0 | mem_val;
	set_zsp_b(bnib0);
}

# --- direct address ---
# OR r1,Addr32
:OR nib0,Addr32 is op8=0x45 & nib1=0 & nib0; Addr32 
{
    nib0 = nib0 | *[ram]Addr32;
	set_zs_w(nib0);
}

# ORB r1,Addr32
:ORB bnib0,Addr32 is op8=0x44 & nib1=0 & bnib0; Addr32 
{
    bnib0 = bnib0 | *[ram]Addr32;
	set_zsp_b(bnib0);
}

# --- indexed address ---
# OR r1,Addr32(rs)
:OR nib0,Addr32(nib1) is op8=0x45 & nib1 & nib0; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:2 = *[ram]:2 (addr + zext(nib1));
    nib0 = nib0 | mem_val;
	set_zs_w(nib0);
}

# ORB r1,Addr32(rs)
:ORB bnib0,Addr32(nib1) is op8=0x44 & nib1 & bnib0; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:1 = *[ram]:1 (addr + zext(nib1));
    bnib0 = bnib0 | mem_val;
	set_zsp_b(bnib0);
}

# OTDR/SOTDR p 148
# OTDR @r1,@rr2,r
:OTDR @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0xA; nib7=0 & nib6 & nib5 & nib4=0 {}
:OTDRB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0xA; nib7=0 & nib6 & nib5 & nib4=0 {}
:SOTDR @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0xB; nib7=0 & nib6 & nib5 & nib4=0 {}
:SOTDRB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0xB; nib7=0 & nib6 & nib5 & nib4=0 {}

# OTIR/SOTIR p 150
# OTIR @r1,@rr2,r
:OTIR @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0x2; nib7=0 & nib6 & nib5 & nib4=0 {}
:OTIRB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0x2; nib7=0 & nib6 & nib5 & nib4=0 {}
:SOTIR @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0x3; nib7=0 & nib6 & nib5 & nib4=0 {}
:SOTIRB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0x3; nib7=0 & nib6 & nib5 & nib4=0 {}

# OUT/SOUT p 152
# --- indirect ---
# OUT @r1,r2
:OUT @nib1,nib0 is op8=0x3F & nib1 & nib0 {}
:OUTB @nib1,nib0 is op8=0x3E & nib1 & nib0 {}

# --- direct address ---
:OUT imm16,nib1 is op8=0x3B & nib1 & nib0=0x6; imm16 {}
:OUTB imm16,bnib1 is op8=0x3A & bnib1 & nib0=0x6; imm16 {}
:SOUT imm16,nib1 is op8=0x3B & nib1 & nib0=0x7; imm16 {}
:SOUTB imm16,bnib1 is op8=0x3A & bnib1 & nib0=0x7; imm16 {}

# OUTD/SOUTD p 153
# OUTD @r1,@rr2,r
:OUTD @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0xA; nib7=0 & nib6 & nib5 & nib4=0x8 {}
:OUTDB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0xA; nib7=0 & nib6 & nib5 & nib4=0x8 {}
:SOUTD @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0xB; nib7=0 & nib6 & nib5 & nib4=0x8 {}
:SOUTDB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0xB; nib7=0 & nib6 & nib5 & nib4=0x8 {}

# OUTI @r1,@rr2,r
:OUTI @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0x2; nib7=0 & nib6 & nib5 & nib4=0x8 {}
:OUTIB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0x2; nib7=0 & nib6 & nib5 & nib4=0x8 {}
:SOUTI @nib5,@dnib1,nib6 is op8=0x3B & dnib1 & nib0=0x3; nib7=0 & nib6 & nib5 & nib4=0x8 {}
:SOUTIB @nib5,@dnib1,nib6 is op8=0x3A & dnib1 & nib0=0x3; nib7=0 & nib6 & nib5 & nib4=0x8 {}

# POP p 156
# --- registers  ---
