macro dynamic_jump(target) 
{
    goto [target];
}

# Create a macro that performs the conditional calculation
macro check_base_cc(base,z,s,v,c,result) 
{
    if (base == 0) goto <c0>;
    if (base == 1) goto <c1>;
    if (base == 2) goto <c2>;
    if (base == 3) goto <c3>;
    if (base == 4) goto <c4>;
    if (base == 5) goto <c5>;
    if (base == 6) goto <c6>;
    result = z; goto <exit>; # Fallback for base == 7

    <c0> result = 0; goto <exit>;
    <c1> result = (z | (s ^ v)); goto <exit>;
    <c2> result = (s ^ v); goto <exit>;
    <c3> result = c; goto <exit>;
    <c4> result = s; goto <exit>;
    <c5> result = v; goto <exit>;
    <c6> result = c; goto <exit>;
    
    <exit>
}

# ---------------------------------------------------------
# Subtables
# ---------------------------------------------------------
flg_list: ""        is flg_all=0x0 {}
flg_list: "v"       is flg_all=0x1 {}
flg_list: "s"       is flg_all=0x2 {}
flg_list: "s,v"     is flg_all=0x3 {}
flg_list: "z"       is flg_all=0x4 {}
flg_list: "z,v"     is flg_all=0x5 {}
flg_list: "z,s"     is flg_all=0x6 {}
flg_list: "z,s,v"   is flg_all=0x7 {}
flg_list: "c"       is flg_all=0x8 {}
flg_list: "c,v"     is flg_all=0x9 {}
flg_list: "c,s"     is flg_all=0xA {}
flg_list: "c,s,v"   is flg_all=0xB {}
flg_list: "c,z"     is flg_all=0xC {}
flg_list: "c,z,v"   is flg_all=0xD {}
flg_list: "c,z,s"   is flg_all=0xE {}
flg_list: "c,z,s,v" is flg_all=0xF {}

# VI:  1
# NVI: 0
int_list: ""        is int_mask=0x3 {}
int_list: "NVI"     is int_mask=0x2 {}
int_list: "VI"      is int_mask=0x1 {}
int_list: "VI,NVI" is int_mask=0x0 {}

# SUBTABLE 1: Jump Relative (JR)
eval_jr: is cc_jr 
{
	local raw_cc:1 = cc_jr;
    local base:1 = raw_cc & 0x07;
    local cond:1 = 0;
    check_base_cc(base,zf,sf,vf,cf,cond);
    if (raw_cc >= 8) goto <done>;
    cond = !cond;
    <done>
    export cond;
}

# SUBTABLE 2: Jump Absolute (JP)
eval_jp: is cc_jp 
{
	local raw_cc:1 = cc_jp;
    local base:1 = raw_cc & 0x07;
    local cond:1 = 0;
    check_base_cc(base,zf,sf,vf,cf,cond);
    if (raw_cc >= 8) goto <done>;
    cond = !cond;
    <done>
    export cond;
}

# ---------------------------------------------------------
# Instructions
# ---------------------------------------------------------
# --- registers  ---
# ADC r1,r2
:ADC nib0,nib1 is op8=0xB5 & nib1 & nib0 
{
	local op1:2 = nib0;
	local op2:2 = nib1;
    local result:2 = op1 + op2 + zext(cf);
	set_fl_16(nib0, op1, op2, result, cf);
}

# ADCB rx1,rx2
:ADCB bnib0,bnib1 is op8=0xB4 & bnib1 & bnib0 
{
	local op1:1 = bnib0;
	local op2:1 = bnib1;
    local result:1 = op1 + op2 + cf;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# --- registers  ---
# ADD r1,r2
:ADD nib0,nib1 is op8=0x81 & nib1 & nib0 
{
	local op1:2 = nib0;
	local op2:2 = nib1;
    local result:2 = op1 + op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# ADDB rx1,rx2
:ADDB bnib0,bnib1 is op8=0x80 & bnib1 & bnib0 
{
	local op1:1 = bnib0;
	local op2:1 = bnib1;
    local result:1 = op1 + op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# ADDL rr1,rr2
:ADDL dnib0,dnib1 is op8=0x96 & dnib0 & dnib1 
{
	local op1:4 = dnib0;
	local op2:4 = dnib1;
    local result:4 = op1 + op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- immediate ---
# ADD r1,#val16
:ADD nib0,#imm16 is op8=0x01 & nib1=0 & nib0; imm16 
{
	local op1:2 = nib0;
    local op2:2 = imm16;
    local result:2 = op1 + op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# ADDB r1,#val16
:ADDB bnib0,#imm16 is op8=0x00 & nib1=0 & bnib0; imm16 
{
	local op1:1 = bnib0;
    local op2:1 = imm16 & 0xff;
    local result:1 = op1 + op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# ADDL r1,#val32
:ADDL dnib0,#imm32 is op8=0x16 & dnib1=0 & dnib0; imm32 
{
	local op1:4 = dnib0;
    local op2:4 = imm32;
    local result:4 = op1 + op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- indirect reg ---
# ADD r1,@r2
:ADD nib0,@dnib1 is op8=0x01 & dnib1 & nib0 
{
	local op1:2 = nib0;
    local addr:4 = dnib1;
    local op2:2 = *[ram]:2 addr;
    local result:2 = op1 + op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# ADDB r1,@r2
:ADDB bnib0,@dnib1 is op8=0x00 & dnib1 & bnib0 
{
	local op1:1 = bnib0;
    local addr:4 = dnib1;
    local op2:1 = *[ram]:2 addr;
    local result:1 = op1 + op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# ADDL r1,@r2
:ADDL dnib0,@dnib1 is op8=0x16 & dnib1 & dnib0 
{
	local op1:4 = dnib0;
    local addr:4 = dnib1;
    local op2:4 = *[ram]:2 addr;
    local result:4 = op1 + op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- direct address ---
# ADD r1,Addr32
:ADD nib0,Addr32 is op8=0x41 & nib1=0 & nib0; Addr32 
{
	local op1:2 = nib0;
    local op2:2 = *[ram]Addr32;
    local result:2 = op1 + op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# ADDB r1,Addr32
:ADDB bnib0,Addr32 is op8=0x40 & nib1=0 & bnib0; Addr32 
{
	local op1:1 = bnib0;
    local op2:1 = *[ram]Addr32;
    local result:1 = op1 + op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# ADDL r1,Addr32
:ADDL dnib0,Addr32 is op8=0x56 & nib1=0 & dnib0; Addr32 
{
	local op1:4 = dnib0;
    local op2:4 = *[ram]Addr32;
    local result:4 = op1 + op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# --- indexed address ---
# ADD r1,Addr32(rs)
:ADD nib0,Addr32(nib1) is op8=0x41 & nib1 & nib0; Addr32 
{
	local op1:2 = nib0;
    local addr:4 = zext(nib1);
    local op2 = *[ram](addr + zext(nib1));
    local result:2 = op1 + op2;
	set_fl_16(nib0, op1, op2, result, cf);
}

# ADDB r1,Addr32(rs)
:ADDB bnib0,Addr32(nib1) is op8=0x40 & nib1 & bnib0; Addr32 
{
	local op1:1 = bnib0;
    local addr:4 = zext(nib1);
    local op2:1 = *[ram]:1 (addr + zext(nib1));
    local result:1 = op1 + op2;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# ADDL rr1,Addr32(rs)
:ADDL dnib0,Addr32(nib1) is op8=0x56 & nib1 & dnib0; Addr32 
{
	local op1:4 = dnib0;
    local addr:4 = zext(nib1);
    local op2:4 = *[ram]:4 (addr + zext(nib1));
    local result:4 = op1 + op2;
	set_fl_32(dnib0, op1, op2, result, cf);
}

# p60
# --- registers  ---
# AND r1,r2
:AND nib0,nib1 is op8=0x87 & nib1 & nib0 
{
    nib0 = nib0 & nib1;
	set_zs_w(nib0);
}

# ANDB r1,r2
:ANDB bnib0,bnib1 is op8=0x86 & bnib1 & bnib0 
{
    bnib0 = bnib0 & bnib1;
	set_zsp_b(bnib0);
}

# --- immediate ---
# AND r1,#val16
:AND nib0,#imm16 is op8=0x07 & nib1=0 & nib0; imm16 
{
    local imm_val:2 = imm16;
    nib0 = nib0 & imm_val;
	set_zs_w(nib0);
}

# ANDB r1,#val16
:ANDB bnib0,#imm16 is op8=0x06 & nib1=0 & bnib0; imm16 
{
    local imm_val = imm16;
    bnib0 = bnib0 & imm_val;
	set_zsp_b(bnib0);
}

# --- indirect reg ---
# AND r1,@r2
:AND nib0,@dnib1 is op8=0x07 & dnib1 & nib0 
{
    local addr:4 = dnib1;
    local mem_val:2 = *[ram]:2 addr;
    nib0 = nib0 & mem_val;
	set_zs_w(nib0);
}

# ANDB r1,@r2
:ANDB bnib0,@dnib1 is op8=0x06 & dnib1 & bnib0 
{
    local addr:4 = dnib1;
    local mem_val = *[ram]addr;
    bnib0 = bnib0 & mem_val;
	set_zsp_b(bnib0);
}

# --- direct address ---
# AND r1,Addr32
:AND nib0,Addr32 is op8=0x47 & nib1=0 & nib0; Addr32 
{
    nib0 = nib0 & *[ram]Addr32;
	set_zs_w(nib0);
}

# ANDB r1,Addr32
:ANDB bnib0,Addr32 is op8=0x46 & nib1=0 & bnib0; Addr32 
{
    bnib0 = bnib0 & *[ram]Addr32;
	set_zsp_b(bnib0);
}

# --- indexed address ---
# AND r1,Addr32(rs)
:AND nib0,Addr32(nib1) is op8=0x47 & nib1 & nib0; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:2 = *[ram]:2 (addr + zext(nib1));
    nib0 = nib0 & mem_val:2;
	set_zs_w(nib0);
}

# ANDB r1,Addr32(rs)
:ANDB bnib0,Addr32(nib1) is op8=0x46 & nib1 & bnib0; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val = *[ram](addr + zext(nib1));
    bnib0 = bnib0 & mem_val;
	set_zsp_b(bnib0);
}

#BIT p 62
# === dynamic ===
# --- registers  ---
# BIT r1,r2
:BIT nib2,nib0 is op8=0x27 & nib1=0 & nib0; nib3=0 & nib2 & byte0=0 
{
    local mask:2 = 1 << nib0;
    zf = ((nib2 & mask) == 0);
}

# BITB r1,r2
:BITB bnib2,nib0 is op8=0x26 & nib1=0 & nib0; nib3=0 & bnib2 & byte0=0 
{
    local mask:1 = 1 << nib0;
    zf = ((bnib2 & mask) == 0);
}

# === static ===
# --- registers ---
# BIT r1,#bit_index
:BIT nib1,#nib0 is op8=0xA7 & nib1 & nib0 
{
    local mask:2 = 1 << nib0;
    zf = ((nib1 & mask) == 0);
}

# BITB r1,#bit_index
:BITB bnib1,#nib0 is op8=0xA6 & bnib1 & nib0 
{
    local mask:1 = 1 << nib0;
    zf = ((bnib1 & mask) == 0);
}

# --- indirect reg ---
# BIT @r1,#bit_index
:BIT @dnib1,#nib0 is op8=0x27 & dnib1 & nib0 
{
    local addr:4 = dnib1;
	local tmp:2 = *[ram]:2 addr;
    local mask:2 = 1 << nib0;
    zf = ((tmp & mask) == 0);
}

# BITB @r1,#bit_index
:BITB @dnib1,#nib0 is op8=0x26 & dnib1 & nib0 
{
    local addr:4 = dnib1;
	local tmp:1 = *[ram]:1 addr;
    local mask:1 = 1 << nib0;
    zf = ((tmp & mask) == 0);
}

# --- direct address ---
# BIT Addr32,#bit_index
:BIT Addr32,#nib0 is op8=0x67 & nib1=0 & nib0; Addr32 
{
	local tmp:2 = *[ram]:2 Addr32;
    local mask:2 = 1 << nib0;
    zf = ((tmp & mask) == 0);
}

# BITB Addr32,#bit_index
:BITB Addr32,#nib0 is op8=0x66 & nib1=0 & nib0; Addr32 
{
	local tmp:1 = *[ram]:2 Addr32;
    local mask:1 = 1 << nib0;
    zf = ((tmp & mask) == 0);
}

# --- indexed address ---
# BIT Addr32(rs),#bit_index
:BIT Addr32(nib1),#nib0 is op8=0x67 & nib1 & nib0; Addr32 
{
    local addr:4 = zext(nib1);
    local tmp:2 = *[ram]:2 (addr + zext(nib1));
    *[ram]:2 (addr + zext(nib1)) = 0;
    local mask:2 = 1 << nib0;
    zf = ((tmp & mask) == 0);
}

# BITB Addr32(rs),#bit_index
:BITB Addr32(nib1),#nib0 is op8=0x66 & nib1 & nib0; Addr32 
{
    local addr:4 = zext(nib1);
    local tmp:1 = *[ram]:1 (addr + zext(nib1));
    *[ram]:1 (addr + zext(nib1)) = 0;
    local mask:1 = 1 << nib0;
    zf = ((tmp & mask) == 0);
}

#CALL p 64
# CALL @rr1
:CALL @dnib1 is op8=0x1F & dnib1 & nib0=0 
{
	local target:4 = dnib1;
    call [target];
}

# CALL Addr32
:CALL Addr32 is op16=0x5F00; Addr32 
{
    call [Addr32];
}

#CALL Addr32(rd)
:CALL Addr32(nib1) is op8=0x5F & nib1 & nib0=0; Addr32 
{
    local addr:4 = zext(nib1);
    local tmp:4 = *[ram]:4 (addr + zext(nib1));
	call [tmp];
}

#CALR p 65
:CALR rel12 is op4=0xD & rel12 
{
    call rel12;
}

#CLR p 66
# --- registers  ---
# CLR r1
:CLR nib1 is op8=0x8D & nib1 & nib0=0x8 
{
    nib1 = 0;
}

# CLRB r1
:CLRB bnib1 is op8=0x8C & bnib1 & nib0=0x8 
{
    bnib1 = 0;
}

# --- indirect reg ---
# CLR @r1
:CLR @dnib1 is op8=0x0D & dnib1 & nib0=0x8 
{
    local addr:4 = dnib1;
    *[ram]:2 addr = 0;
}

# CLRB @r1
:CLRB @dnib1 is op8=0x0C & dnib1 & nib0=0x8 
{
    local addr:4 = dnib1;
    *[ram]:1 addr = 0;
}

# --- direct address ---
# CLR Addr32
:CLR Addr32 is op16=0x4D08; Addr32 
{
	*[ram]:2 Addr32 = 0;
}

# CLRB Addr32
:CLRB Addr32 is op16=0x4C08; Addr32 
{
	*[ram]:1 Addr32 = 0;
}

# --- indexed address ---
# CLR Addr32(rs)
:CLR Addr32(nib1) is op8=0x4D & nib1 & nib0=0x8; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:2 = *[ram]:2 (addr + zext(nib1));

    *[ram]:2 (addr + zext(nib1)) = 0;
}

# CLRB Addr32(rs)
:CLRB Addr32(nib1) is op8=0x4C & nib1 & nib0=0x8; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:1 = *[ram]:1 (addr + zext(nib1));

    *[ram]:1 (addr + zext(nib1)) = 0;
}

# COM p 67
# COM r1
:COM nib1 is op8=0x8D & nib1 & nib0=0 
{
    nib1 = ~nib1;
	set_zs_w(nib1);
}

# COMB r1
:COMB bnib1 is op8=0x8C & bnib1 & nib0=0 
{
    bnib1 = ~bnib1;
	set_zsp_b(bnib1);
}

# --- indirect reg ---
# COM @r1
:COM @dnib1 is op8=0x0D & dnib1 & nib0=0 
{
    local addr:4 = dnib1;
    local res:2 = ~(*[ram]:2 addr);
    dnib1 = zext(res);
	set_zs_w(res);
}

# COMB @r1
:COMB @dnib1 is op8=0x0C & dnib1 & nib0=0 
{
    local addr:4 = dnib1;
    local res:1 = ~(*[ram]:1 addr);
    dnib1 = zext(res);
	set_zsp_b(res);
}

# --- direct address ---
# COM Addr32
:COM Addr32 is op8=0x4D & nib1=0 & nib0=0; Addr32 
{
    local res:2 = ~(*[ram]Addr32);
	*[ram]Addr32 = res;
	set_zs_w(res);
}

# COMB Addr32
:COMB Addr32 is op8=0x4C & nib1=0 & nib0=0; Addr32 
{
    local res:1 = ~(*[ram]Addr32);
	*[ram]Addr32 = res;
	set_zsp_b(res);
}

# --- indexed address ---
# COM Addr32(rs)
:COM Addr32(nib1) is op8=0x4D & nib1 & nib0=0; Addr32 
{
    local addr:4 = zext(nib1);
    local res:2 = ~(*[ram]:2 (addr + zext(nib1)));
    *[ram]:2 (addr + zext(nib1)) = res;
	set_zs_w(res);
}

# COMB Addr32(rs)
:COMB Addr32(nib1) is op8=0x4C & nib1 & nib0=0; Addr32 
{
    local addr:4 = zext(nib1);
    local res:1 = ~(*[ram]:1 (addr + zext(nib1)));
    *[ram]:1 (addr + zext(nib1)) = res;
	set_zsp_b(res);
}

# p 68
#COMFLAG
:COMFLG flg_list is op8=0x8D & flg_list & flg_c & flg_z & flg_s & flg_v & nib0=0x5 
{
	cf = cf ^ flg_c;
    zf = zf ^ flg_z;
    sf = sf ^ flg_s;
    vf = vf ^ flg_v;
}

# CP p 69
