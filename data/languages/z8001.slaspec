:CPSIB @dnib5,@dnib1,nib6,cc_jp is op8=0xBA & dnib1 & nib0=0x2; nib7=0 & nib6 & dnib5 & eval_jp & cc_jp {}

# CPSIR p 83
# CPSIR @r1,@r2,r,cc
