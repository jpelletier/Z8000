# ---------------------------------------------------------
# CORE ARCHITECTURE DEFINITIONS
# ---------------------------------------------------------
define endian=big;
define alignment=2;

# 4 bytes tracking the 32-bit (Segment + Offset) storage space
define space ram         type=ram_space      size=4 wordsize=2 default; 
define space register    type=register_space size=4;

# ---------------------------------------------------------
# 8-bit registers (1 byte each,overlapping r0 through r7)
define register offset=0x00 size=1 [ rh0 rl0 rh1 rl1 rh2 rl2 rh3 rl3 rh4 rl4 rh5 rl5 rh6 rl6 rh7 rl7 ];

# 16-bit individual registers (Sequential, 2 bytes each, offsets 0x00-0x1F)
define register offset=0x00 size=2 [ r0 r1 r2 r3 r4 r5 r6 r7 r8 r9 r10 r11 r12 r13 r14 r15 ];

# 32-bit register pairs (Overlapping, 4 bytes each, offsets 0x00-0x1F)
# Z8000 uses only even indices. We use underscores '_' to skip odd offset slots.
define register offset=0x00 size=4 [ rr0 _ rr2 _ rr4 _ rr6 _ rr8 _ rr10 _ rr12 _ rr14 _ ];

# 64-bit register quads (Overlapping, 8 bytes each, offsets 0x00-0x1F)
# Z8000 uses indices divisible by 4. Underscores '_' skip the intermediate slots.
define register offset=0x00 size=8 [ rq0 _ _ _ rq4 _ _ _ rq8 _ _ _ rq12 _ _ _ ];

# ---------------------------------------------------------
# Program Counter & System Registers
# ---------------------------------------------------------
# Placed safely outside the R0-R15 register file window (0x00 - 0x1F)
define register offset=0x40 size=4 [ pc ];

# Status Register (FCW)
define register offset=0x200 size=2 [ DUMMY0 DUMMY1 FCW REFRESH PSAPSEG PSAPOFF NSPSEG NSPOFF ];

# Slice flags from the 16-bit FCW register (Ghidra Index = 15 - Native_Z8000_Bit)
define bitrange 
    seg=FCW[0,1]  sys=FCW[1,1]  epa=FCW[2,1]  vie=FCW[3,1]  nvie=FCW[4,1]
    cf=FCW[10,1]  zf=FCW[11,1]  sf=FCW[12,1]  pf=FCW[13,1]  df=FCW[14,1]
    hf=FCW[15,1]  vf=FCW[13,1];

# Define unmapped temporary registers for math operations
define register offset=0x300 size=4 [ tmp_addr tmp_seg tmp_off ];

# ---------------------------------------------------------
# Tokens and Context
# ---------------------------------------------------------
define token opword (16)
    op16     = ( 0,15)   # Full 16-bit word for exact opcode matching
	op14	 = ( 2,15)	 # For DI, EI
    op8      = ( 8,15)
	op4  	 = (12,15)
	ctlr	 = ( 0, 2)
	#ctlr_val = ( 0, 2)  # Mirror field for constraints
	dirr	 = ( 3, 3)
    cc_jp  	 = ( 0, 3)
    cc_jr  	 = ( 8,11)
    imm16    = ( 0,15)
	imm_sign = ( 15,15)
    disp16   = ( 0,15)   signed
    disp12   = ( 0,11)   signed
	disp8	 = ( 0, 7)   signed
	disp7	 = ( 0, 6)
	byte0	 = ( 0, 7)

	nib7	 = (12,15)
    nib6	 = ( 8,11)
	nib5	 = ( 4, 7)
    nib4	 = ( 0, 3)
	nib3	 = (12,15)
    nib2	 = ( 8,11)
	nib1	 = ( 4, 7)
    nib0	 = ( 0, 3)

	bnib7	 = (12,15)
    bnib6	 = ( 8,11)
	bnib5	 = ( 4, 7)
    bnib4	 = ( 0, 3)
	bnib3	 = (12,15)
    bnib2	 = ( 8,11)
	bnib1	 = ( 4, 7)
    bnib0	 = ( 0, 3)

	dnib5	 = ( 4, 7)
	dnib1	 = ( 4, 7)
    dnib0	 = ( 0, 3)
	qnib1	 = ( 4, 7)
    qnib0	 = ( 0, 3)

    value0	 = ( 0, 3)
	flg_all  = ( 4, 7)

    flg_c    = ( 7, 7)  # Carry Flag bit
    flg_z    = ( 6, 6)  # Zero Flag bit
    flg_s    = ( 5, 5)  # Sign Flag bit
    flg_v    = ( 4, 4)  # Overflow Flag bit

	# Bits 0 and 1 specify which interrupts to target (Bit 1 = VI, Bit 0 = NVI)
	int_mask = ( 0, 1)  # Combines both interrupt selection bits

    int_vi   = ( 1, 1)  # For DI, EI
    int_nvi  = ( 0, 0)  # For DI, EI

	W        = ( 7, 7)  # DJNZ
;

define token extension (16)
    # Additional common fields for Z8001 bit patterns
    seg_num  = ( 8,14)  # 7-bit segment number
	off8	 = ( 0, 7)   # 8-bit offset
    off16    = ( 0,15)

    size_bit = (11,11)
    seg_bit  = (15,15) # Segmented flag bit
;

# Token for 32-bit fields (used for absolute segmented memory addresses/immediates)
define token data32 (32)
	imm32 = (0, 31)
    imm32_seg = (16, 31)
    imm32_off = (0, 15)
;

# ---------------------------------------------------------
# Attach Sections
# ---------------------------------------------------------
attach names [ cc_jp cc_jr ] 
[
    "F" "LT" "LE" "ULE" "OV"  "MI" "Z"  "C"
    "T" "GE" "GT" "UGT" "NOV" "PL" "NZ" "NC"
];

attach variables [ ctlr ]
[
	DUMMY0 DUMMY1 FCW REFRESH PSAPSEG PSAPOFF NSPSEG NSPOFF
];

attach variables [ nib0 nib1 nib2 nib5 nib6]
[
    r0  r1  r2  r3  r4  r5  r6  r7 
    r8  r9  r10 r11 r12 r13 r14 r15 
];

attach variables [ bnib0 bnib1 bnib2 bnib5 bnib6]
[
    rh0  rh1  rh2  rh3  rh4  rh5  rh6  rh7 
    rl0  rl1  rl2  rl3  rl4  rl5  rl6  rl7 
];

# Map 4-bit token indices to 32-bit register pairs for indirect memory instructions
# Z8000 uses even-numbered register indices for 32-bit pairs (rr0, rr2, etc.)
attach variables [ dnib0 dnib1 dnib5 ] 
[
    rr0 _ rr2 _ rr4 _ rr6 _
    rr8 _ rr10 _ rr12 _ rr14 _
];

# Map 4-bit token indices to 64-bit register quads for indirect memory instructions
# Z8000 uses even-numbered register indices for 64-bit quads (rq0, rq4, etc.)
attach variables [ qnib0 qnib1 ] 
[
    rq0 _ _ _ rq4 _ _ _
    rq8 _ _ _ rq12 _ _ _
];

# Attach the displacement relative calculation to a target operand
rel16: RelAddr16 is disp16
[
	RelAddr16 = inst_next + disp16;
]{ export RelAddr16; }

# Attach the displacement relative calculation to a target operand
rel12: RelAddr12 is disp12
[
	RelAddr12 = inst_next + disp12;
]{ export RelAddr12; }

# Attach the displacement relative calculation to a target operand
rel8: RelAddr8 is disp8 
[
	RelAddr8 = inst_next + disp8;
]{ export RelAddr8; }

rel7: RelAddr7 is disp7 
[
	RelAddr7 = inst_next - disp7;
]{ export RelAddr7; }

# ---------------------------------------------------------
# Macros
# ---------------------------------------------------------
# 24-bit/32-bit Segmented Address Parsing (Decoding the Z8001 Intersegment formatting)
Addr32: seg_num, off16 is seg_bit=1 & seg_num; off16 
{
    local tmp:4 = (seg_num << 16) | off16;
    export tmp;
}

Addr32: off16 is seg_bit=0 & off16 
{
    # Short segment form (implied segment or 8-bit offset form)
    local tmp:4 = off16;
    export tmp;
}

# Macro: Reconstruct a linear 32-bit address from a Z8001 segment/offset pair
# Input: 32-bit register pair or memory pointer (e.g., RR2 or a long pointer)
macro getLinearAddress(ptr32, result) 
{
    # Extract segment: bits 16-22 of the 32-bit layout (Big Endian)
    tmp_seg = (ptr32 >> 16) & 0x7F;
    
    # Extract offset: lowest 16 bits
    tmp_off = ptr32 & 0xFFFF;
    
    # Calculate linear address: (Segment * 0x10000) + Offset
    result = (tmp_seg << 16) + tmp_off;
}

macro push16(val) 
{
    # 1. Decrement the 16-bit offset portion of the Stack Pointer (rr14 low half)
    r15 = r15 - 2:2;
    
    # 2. Store the 16-bit value onto the RAM space at the address formed by rr14
    *:2 rr14 = val;
}

macro push32(val) 
{
    # 1. Decrement the 16-bit offset portion of the Stack Pointer by 4 bytes
    r15 = r15 - 4:2;
    
    # 2. Store the 32-bit value onto the RAM space at the address formed by rr14
    *:4 rr14 = val;
}

macro pop16(dst) 
{
    # 1. Read the 16-bit value from RAM at the current rr14 address
    dst = *:2 rr14;
    
    # 2. Increment the 16-bit offset portion of the Stack Pointer (r15)
    r15 = r15 + 2:2;
}

macro pop32(dst) 
{
    # 1. Read the 32-bit value from RAM at the current rr14 address
    dst = *:4 rr14;
    
    # 2. Increment the 16-bit offset portion of the Stack Pointer (r15)
    r15 = r15 + 4:2;
}

# Global macro to compute and set Z8001 Zero and Sign flags
macro set_zs_b(result) 
{
    zf = (result == 0:1);
    sf = ((result & 0x80:1) != 0:1);
}

macro set_zs_w(result) 
{
    zf = (result == 0:2);
    sf = ((result & 0x8000:2) != 0:2);
}

macro set_zs_d(result) 
{
    zf = (result == 0:4);
    sf = ((result & 0x80000000:4) != 0:4);
}

# ADC, ADD, SBC, SUB
# Arguments: Destination, Operand1, Operand2, Result, CarryIn
macro set_fl_8(dest, op1, op2, res, cin) {
    cf = (res < op1) || ((cin == 1) && (res == op1));
    zf = (res == 0);
    sf = (res >= 0x80);
    vf = (((op1 ^ res) & (op2 ^ res)) >= 0x80);
	df = 0;
	hf = (((op1 ^ op2 ^ res) & 0x10) == 0x10);
    dest = res;
}

macro set_fl_16(dest, op1, op2, res, cin) {
    cf = (res < op1) || ((cin == 1) && (res == op1));
    zf = (res == 0);
    sf = (res >= 0x8000);
    vf = (((op1 ^ res) & (op2 ^ res)) >= 0x8000);
    dest = res;
}

macro set_fl_32(dest, op1, op2, res, cin) {
    cf = (res < op1) || ((cin == 1) && (res == op1));
    zf = (res == 0);
    sf = (res >= 0x80000000);
    vf = (((op1 ^ res) & (op2 ^ res)) >= 0x80000000);
    dest = res;
}

# CP
# Arguments: Destination, Operand1, Operand2, Result
macro set2_fl_8(op1, op2, res) {
    cf = (res < op1);
    zf = (res == 0);
    sf = (res >= 0x80);
    vf = (((op1 ^ res) & (op2 ^ res)) >= 0x80);
	df = 0;
	hf = (((op1 ^ op2 ^ res) & 0x10) == 0x10);
}

macro set2_fl_16(op1, op2, res) {
    cf = (res < op1);
    zf = (res == 0);
    sf = (res >= 0x8000);
    vf = (((op1 ^ res) & (op2 ^ res)) >= 0x8000);
}

macro set2_fl_32(op1, op2, res) {
    cf = (res < op1);
    zf = (res == 0);
    sf = (res >= 0x80000000);
    vf = (((op1 ^ res) & (op2 ^ res)) >= 0x80000000);
}

# FIXME Generates Unnecessary truncation(:) warnings
macro calculateParity(val,pf) {
    local b0 = val[0,1];
    local b1 = val[1,1];
    local b2 = val[2,1];
    local b3 = val[3,1];
    local b4 = val[4,1];
    local b5 = val[5,1];
    local b6 = val[6,1];
    local b7 = val[7,1];
    
    # XOR all bits together
    # PF = 1 if even, 0 if odd
    pf = !(b0 ^ b1 ^ b2 ^ b3 ^ b4 ^ b5 ^ b6 ^ b7);
}

# FIXME Generates Unnecessary truncation(:) warnings
macro calculateParity16(val,pf) {
    local b0  = val[0,1];
    local b1  = val[1,1];
    local b2  = val[2,1];
    local b3  = val[3,1];
    local b4  = val[4,1];
    local b5  = val[5,1];
    local b6  = val[6,1];
    local b7  = val[7,1];
    local b8  = val[8,1];
    local b9  = val[9,1];
    local b10 = val[10,1];
    local b11 = val[11,1];
    local b12 = val[12,1];
    local b13 = val[13,1];
    local b14 = val[14,1];
    local b15 = val[15,1];
    
    # XOR all bits together
    # PF = 1 if even, 0 if odd
    pf = !(b0 ^ b1 ^ b2 ^ b3 ^ b4 ^ b5 ^ b6 ^ b7 ^ b8 ^ b9 ^ b10 ^ b11 ^ b12 ^ b13 ^ b14 ^ b15);
}

