# XOR p 211
# --- registers  ---
# XOR r1,r2
:XOR nib0,nib1 is op8=0x89 & nib1 & nib0 
{
    nib0 = nib0 ^ nib1;
	set_zs_w(nib0);
}

# XORB r1,r2
:XORB bnib0,bnib1 is op8=0x88 & bnib1 & bnib0 
{
    bnib0 = bnib0 ^ bnib1;
	set_zsp_b(bnib0);
}

# --- immediate ---
# XOR r1,#val16
:XOR nib0,#imm16 is op8=0x09 & nib1=0 & nib0; imm16 
{
    local imm_val:2 = imm16;
    nib0 = nib0 ^ imm_val;
	set_zs_w(nib0);
}

# XORB r1,#val16
:XORB bnib0,#imm16 is op8=0x08 & nib1=0 & bnib0; imm16 
{
    local imm_val:1 = imm16;
    bnib0 = bnib0 ^ imm_val;
	set_zsp_b(bnib0);
}

# --- indirect reg ---
# XOR r1,@r2
:XOR nib0,@dnib1 is op8=0x09 & dnib1 & nib0 
{
    local addr:4 = dnib1;
    local mem_val:2 = *[ram]:2 addr;
    nib0 = nib0 ^ mem_val;
	set_zs_w(nib0);
}

# XORB r1,@r2
:XORB bnib0,@dnib1 is op8=0x08 & dnib1 & bnib0 
{
    local addr:4 = dnib1;
    local mem_val:1 = *[ram]addr;
    bnib0 = bnib0 ^ mem_val;
	set_zsp_b(bnib0);
}

# --- direct address ---
# XOR r1,Addr32
:XOR nib0,Addr32 is op8=0x49 & nib1=0 & nib0; Addr32 
{
    nib0 = nib0 ^ *[ram]Addr32;
	set_zs_w(nib0);
}

# XORB r1,Addr32
:XORB bnib0,Addr32 is op8=0x48 & nib1=0 & bnib0; Addr32 
{
    bnib0 = bnib0 ^ *[ram]Addr32;
	set_zsp_b(bnib0);
}

# --- indexed address ---
# XOR r1,Addr32(rs)
:XOR nib0,Addr32(nib1) is op8=0x49 & nib1 & nib0; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:2 = *[ram]:2 (addr + zext(nib1));
    nib0 = nib0 ^ mem_val:2;
	set_zs_w(nib0);
}

# XORB r1,Addr32(rs)
:XORB bnib0,Addr32(nib1) is op8=0x48 & nib1 & bnib0; Addr32 
{
    local addr:4 = zext(nib1);
    local mem_val:1 = *[ram]:1 (addr + zext(nib1));
    bnib0 = bnib0 ^ mem_val;
	set_zsp_b(bnib0);
}
