:PUSH @dnib1,nib0 is op8=0x93 & dnib1 & nib0 {}
# PUSHL rr1,@rr2
:PUSHL @dnib1,dnib0 is op8=0x91 & dnib1 & dnib0 {}

# --- immediate ---
