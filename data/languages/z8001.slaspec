:RRDB nib0,nib1 is op8=0xBC & nib1 & nib0 {}

# SBC p 172
# --- registers  ---
# SBC r1,r2
:SBC nib0,nib1 is op8=0xB7 & nib1 & nib0 
{
	local op1:2 = nib0;
	local op2:2 = nib1;
    local result:2 = op1 - op2 - zext(cf);
	set_fl_16(nib0, op1, op2, result, cf);
}

# SBCB rx1,rx2
:SBCB bnib0,bnib1 is op8=0xB6 & bnib1 & bnib0 
{
	local op1:1 = bnib0;
	local op2:1 = bnib1;
    local result:1 = op1 - op2 - cf;
	set_fl_8(bnib0, op1, op2, result, cf);
}

# SC p 173
# SC #data
:SC #byte0 is op8=0x7F & byte0 {}

# SDA p 175
# SDA r1,r2
:SDA nib1,nib2 is op8=0xB3 & nib1 & nib0=0xB; nib3=0 & nib2 & byte0=0 {}

# SDAB rx1,r2
:SDAB bnib1,nib2 is op8=0xB2 & bnib1 & nib0=0xB; nib3=0 & nib2 & byte0=0 {}

# SDAL rr1,r2
:SDAL dnib1,nib2 is op8=0xB3 & dnib1 & nib0=0xF; nib3=0 & nib2 & byte0=0 {}

# SDL p 177
